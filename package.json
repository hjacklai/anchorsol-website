{
  "name": "anchorsol-wall-site",
  "version": "2.0.0",
  "description": "AnchorSOL Wall — anchorsolwall.com static site.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node tools/optimise-images.mjs --rewrite-html",
    "build:images": "node tools/optimise-images.mjs",
    "build:dry": "node tools/optimise-images.mjs --dry-run",
    "serve": "powershell -ExecutionPolicy Bypass -File .claude/serve.ps1 -Port 8000 -Root site"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  }
}
