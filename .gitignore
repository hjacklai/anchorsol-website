# Dependencies
node_modules/

# Build artefacts (generated by tools/optimise-images.mjs at deploy time)
site/assets/images/*.webp
site/assets/images/*.avif
site/assets/images/_manifest.json
# Exceptions: hand-added webp/avif files that should be tracked
!site/assets/images/dr_lai_yip_poon.webp

# Originals, research, raw source materials (kept locally, not for public repo)
originals/
extracted/
research/
raw videos/
design-pkg/

# Personal / local-only config
.claude/settings.local.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.tmp
*.tmp.drivedownload
.vscode/
.idea/

# Keep .claude/launch.json + .claude/serve.ps1 (useful for local preview)

# Internal-only — never commit
*.pdf
!site/assets/papers/*.pdf

# Internal strategy docs and content generators — kept locally, not public.
# Reveal too much of our SEO playbook and content templates if exposed.
*.md
BACKLINKS_PLAYBOOK.md
OFFSITE_SEO_CHECKLIST.md

# All tools/ scripts except the CI image optimiser (which the GitHub
# Action needs to build the site).
tools/*.pl
tools/*.sh
tools/*.py
tools/inject-tabbar.mjs
!tools/optimise-images.mjs
